{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Academy system (Participant, Speaker, Admin).",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID." },
        "displayName": { "type": "string", "description": "Full name." },
        "email": { "type": "string", "format": "email", "description": "Contact email." },
        "role": { "type": "string", "enum": ["admin", "speaker", "participant"], "description": "User role." },
        "branch": { "type": "string", "description": "Branch/Filial name." },
        "mentorId": { "type": "string", "description": "UID of the mentor." },
        "referrerId": { "type": "string", "description": "UID of the person who invited this user." },
        "bonusBalance": { "type": "number", "description": "Current referral bonuses." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "role"]
    },
    "Event": {
      "title": "Event",
      "description": "A seminar, webinar, or workshop.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Event title." },
        "description": { "type": "string", "description": "Detailed description." },
        "speakerId": { "type": "string", "description": "UID of the speaker." },
        "speakerName": { "type": "string", "description": "Speaker name (denormalized)." },
        "location": { "type": "string", "description": "Venue or 'Online'." },
        "startTime": { "type": "string", "format": "date-time", "description": "Start date and time." },
        "endTime": { "type": "string", "format": "date-time", "description": "End date and time." },
        "price": { "type": "number", "description": "Current price." },
        "maxParticipants": { "type": "number", "description": "Maximum capacity." },
        "registeredCount": { "type": "number", "description": "Number of people registered." },
        "status": { "type": "string", "enum": ["planned", "active", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "speakerId", "startTime", "endTime", "location"]
    },
    "Registration": {
      "title": "Registration",
      "description": "A user's registration for an event.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the participant." },
        "eventId": { "type": "string", "description": "ID of the event." },
        "status": { "type": "string", "enum": ["registered", "attended", "cancelled"] },
        "paid": { "type": "boolean", "description": "Whether the event was paid." },
        "amountPaid": { "type": "number", "description": "Amount paid." },
        "registrationDate": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "eventId", "status"]
    },
    "Finance": {
      "title": "Finance",
      "description": "Financial records (income/expense).",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "category": { "type": "string", "description": "e.g., 'rent', 'speaker_fee', 'registration_fee'" },
        "eventId": { "type": "string", "description": "Related event ID (optional)." },
        "userId": { "type": "string", "description": "Related user ID (optional)." },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "amount", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Academy events."
    },
    "/registrations/{regId}": {
      "schema": "Registration",
      "description": "Event registrations."
    },
    "/finance/{recordId}": {
      "schema": "Finance",
      "description": "Financial records."
    }
  }
}
